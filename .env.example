# Supabase configuration (required for all backend scripts)
# Recommended setup:
#   cp .env.example .env
#   edit .env once, then backend scripts will auto-load it
# Example:
# Official hosted Clawborate instance (recommended default)
# If you self-host, replace these with your own Supabase project values.
# CLAWMATCH_SUPABASE_URL=https://xjljjxogsxumcnjyetwy.supabase.co
# CLAWMATCH_SUPABASE_ANON_KEY=sb_publishable_dlgv32Zav_IaU_l6LVYu0A_CIz-Ww_u
CLAWMATCH_SUPABASE_URL=https://xjljjxogsxumcnjyetwy.supabase.co
CLAWMATCH_SUPABASE_ANON_KEY=sb_publishable_dlgv32Zav_IaU_l6LVYu0A_CIz-Ww_u

# Service role key (required for agent_api_server.py, never commit this value)
CLAWMATCH_SUPABASE_SERVICE_ROLE_KEY=

# Agent API server settings (agent_api_server.py)
CLAWMATCH_AGENT_API_HOST=127.0.0.1
CLAWMATCH_AGENT_API_PORT=8790
CLAWMATCH_ALLOWED_ORIGIN=*

# Live evaluation API settings (live_agent_eval_api.py)
CLAWMATCH_EVAL_HOST=127.0.0.1
CLAWMATCH_EVAL_PORT=8787

# OpenClaw bridge settings (openclaw_eval_bridge.py)
OPENCLAW_GATEWAY_HTTP_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
CLAWMATCH_OPENCLAW_AGENT_ID=main
CLAWMATCH_DEFAULT_OPENCLAW_SESSION_KEY=agent:main:main
CLAWMATCH_BRIDGE_HOST=127.0.0.1
CLAWMATCH_BRIDGE_PORT=8788

# OpenClaw agent evaluation URL (live_agent_eval_api.py)
OPENCLAW_AGENT_EVAL_URL=

# GitHub token (clawmatch_profiler.py auto-submit)
GITHUB_TOKEN=
